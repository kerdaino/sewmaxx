NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1
APP_BASE_URL=http://localhost:3000

MONGODB_URI=mongodb://127.0.0.1:27017/sewmaxx_phase_1
MONGODB_DB_NAME=sewmaxx_phase_1

TELEGRAM_BOT_TOKEN=replace_with_a_long_random_secret
TELEGRAM_BOT_USERNAME=replace_with_your_bot_username
BOT_MODE=polling
BOT_SESSION_TTL_SECONDS=1800
BOT_SESSION_MAX_SESSIONS=5000
TELEGRAM_WEBHOOK_PATH=/webhook/telegram
TELEGRAM_WEBHOOK_SECRET=replace_with_a_long_random_secret
TELEGRAM_WEBHOOK_URL=

LOG_LEVEL=info
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
JSON_BODY_LIMIT=100kb
URLENCODED_BODY_LIMIT=50kb
CORS_ALLOWED_ORIGINS=http://localhost:3000
CORS_ALLOW_CREDENTIALS=false
BOT_SPAM_ENABLED=true
BOT_SPAM_WINDOW_MS=60000
BOT_SPAM_MAX_ACTIONS=8
TAILOR_DEFAULT_STATUS=pending_review
TAILOR_TERMS_PDF_URL=
ADMIN_DEV_TOKEN=replace_with_a_long_random_admin_token
ADMIN_ALLOWED_IPS=
ADMIN_TELEGRAM_IDS=
